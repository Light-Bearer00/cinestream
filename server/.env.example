PORT=5000
MONGODB_URI=mongodb://localhost:27017/cinestream
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development

# Free OMDB API key for auto-fetching movie info (poster, description, rating etc.)
# Get a free key at: https://www.omdbapi.com/apikey.aspx
# Without a key it still works but has a small daily limit
OMDB_API_KEY=trilogy

# TMDB API key — required for the Movie Scraper feature
# Get a FREE key at: https://www.themoviedb.org/settings/api
# Sign up → Settings → API → Create → "Developer" → fill form → copy "API Key (v3 auth)"
TMDB_API_KEY=your_tmdb_api_key_here
